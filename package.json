{
  "name": "inventory",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client && npm run build --workspace=server && node scripts/bundle-api.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@vercel/node": "^5.1.14",
    "concurrently": "^9.1.2",
    "esbuild": "^0.28.1",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0"
  }
}
