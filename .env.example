# Database (Supabase Postgres — used by Prisma)
# Local dev: session pooler port 5432 is fine
# Vercel/serverless: use transaction pooler port 6543 with pgbouncer=true
POSTGRES_URL="postgresql://prisma.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase (server — Vercel Functions only, never expose to client)
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Supabase (client — baked into the Vite build; set on Vercel for Production + Preview)
VITE_SUPABASE_URL="https://[project-ref].supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# App auth (server only)
JWT_SECRET="change-this-to-a-long-random-secret"

# App
NODE_ENV="development"
# Local dev: http://localhost:5173
# Vercel production: https://your-app.vercel.app
CLIENT_URL="http://localhost:5173"
